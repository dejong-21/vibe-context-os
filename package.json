{
  "name": "vibe-context-os",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent Context Doctor for AI coding workflows.",
  "license": "MIT",
  "author": "dejong-21",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dejong-21/vibe-context-os.git"
  },
  "bugs": {
    "url": "https://github.com/dejong-21/vibe-context-os/issues"
  },
  "homepage": "https://github.com/dejong-21/vibe-context-os#readme",
  "keywords": [
    "agent-context",
    "agent-rules",
    "agents-md",
    "ai-coding",
    "context-engineering",
    "codex",
    "claude-code",
    "cursor",
    "developer-tools",
    "mcp",
    "mcp-security",
    "vibe-coding"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vibe-context": "./dist-server/server/cli.js",
    "vibe-context-os": "./dist-server/server/cli.js",
    "agent-context-doctor": "./dist-server/server/cli.js"
  },
  "files": [
    "action.yml",
    "dist",
    "dist-server/server/analyzer.*",
    "dist-server/server/artifactAudit.*",
    "dist-server/server/applyPlan.*",
    "dist-server/server/badge.*",
    "dist-server/server/budget.*",
    "dist-server/server/cli.*",
    "dist-server/server/codexSessions.*",
    "dist-server/server/configDoctor.*",
    "dist-server/server/config.*",
    "dist-server/server/drift.*",
    "dist-server/server/exporter.*",
    "dist-server/server/index.*",
    "dist-server/server/init.*",
    "dist-server/server/mcp.*",
    "dist-server/server/mcpAudit.*",
    "dist-server/server/pack.*",
    "dist-server/server/privacyAudit.*",
    "dist-server/server/publish.*",
    "dist-server/server/scanner.*",
    "dist-server/server/security.*",
    "dist-server/server/status.*",
    "dist-server/server/trace.*",
    "dist-server/server/types.*",
    "dist-server/server/utils.*",
    "dist-server/server/workspaceConfig.*",
    "agent-kit",
    "codex-skill",
    "demo-workspace",
    "scripts",
    "docs",
    ".env.example",
    "README.md",
    "README.zh-CN.md",
    "ROADMAP.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/index.ts",
    "vibe": "tsx server/cli.ts",
    "test": "tsx server/regression.ts",
    "smoke": "tsx server/smoke.ts",
    "demo:scan": "tsx scripts/demo-run.mjs scan",
    "demo:export": "tsx scripts/demo-run.mjs export",
    "demo:public-bundle": "tsx scripts/demo-run.mjs public-bundle",
    "demo:privacy-audit": "tsx scripts/demo-run.mjs privacy-audit",
    "examples:refresh": "tsx scripts/sync-examples.mjs",
    "agent:check": "node scripts/check-agent-native.mjs",
    "agent:install": "node scripts/install-agent-native.mjs",
    "agent:install:codex": "node scripts/install-agent-native.mjs --codex",
    "agent:install:claude-user": "node scripts/install-agent-native.mjs --claude-user",
    "build": "tsc -p tsconfig.node.json && vite build",
    "mcp:smoke": "node dist-server/server/mcpSmoke.js",
    "pack:check": "npm pack --dry-run",
    "package:smoke": "tsx server/packageSmoke.ts",
    "release:check": "npm run lint && npm test && npm run build && npm run smoke && npm run mcp:smoke && npm run vibe -- privacy-audit && npm run vibe -- drift && npm run vibe -- publish-check && npm run vibe -- export && npm run vibe -- public-bundle && npm run vibe -- config-fix-pack && npm run vibe -- artifact-audit && npm run vibe -- mcp-audit && npm run vibe -- config-doctor && npm run vibe -- trace && npm run agent:check && npm run vibe -- artifact-audit && npm run pack:check && npm run package:smoke",
    "prepack": "npm run build",
    "start": "node dist-server/server/index.js",
    "lint": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "fast-glob": "^3.3.2",
    "framer-motion": "^11.18.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
